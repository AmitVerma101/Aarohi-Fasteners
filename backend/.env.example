API_PORT=4000
ADMIN_TOKEN=change-me
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Use false with 587 (STARTTLS), true with 465 (SSL)
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_CONNECTION_TIMEOUT=20000
SMTP_GREETING_TIMEOUT=10000
SMTP_SOCKET_TIMEOUT=20000
CONTACT_TO_EMAIL=sales@example.com
CONTACT_FROM_EMAIL=no-reply@example.com
